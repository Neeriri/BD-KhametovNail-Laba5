<Window x:Class="Laba4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laba4"
        mc:Ignorable="d"
        Title="Управление маркетинговой базой данных" Height="500" Width="900" 
        WindowStartupLocation="CenterScreen"
        Background="#FF2E2E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Label Grid.Row="0" Content="Лабораторная работа №4 - CRUD операции" 
               FontSize="24" HorizontalAlignment="Center" 
               Foreground="#FFE9CB80" VerticalAlignment="Center"/>
        
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
            <Button x:Name="ButtonClients" Content="Клиенты (Clients)" 
                    Width="300" Height="50" Margin="0,10" FontSize="16"
                    Background="#FFE9CB80" Click="ButtonClients_Click"/>
            
            <Button x:Name="ButtonEmployees" Content="Сотрудники (Employees)" 
                    Width="300" Height="50" Margin="0,10" FontSize="16"
                    Background="#FFE9CB80" Click="ButtonEmployees_Click"/>
            
            <Button x:Name="ButtonCampaigns" Content="Кампании (Campaigns)" 
                    Width="300" Height="50" Margin="0,10" FontSize="16"
                    Background="#FFE9CB80" Click="ButtonCampaigns_Click"/>
        </StackPanel>
    </Grid>
</Window>
