<Window x:Class="Laba4.Views.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление клиентами" Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF2E2E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <Label Grid.Row="0" Content="Клиенты (Clients)" 
               FontSize="24" HorizontalAlignment="Center" 
               Foreground="#FFE9CB80" VerticalAlignment="Center"/>
        
        <DataGrid x:Name="DataGridClients" Grid.Row="1" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FF6D6D6D" Foreground="White"
                  SelectionMode="Single" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ClientID}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="200"/>
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Изменить" Background="#FFE9CB80" 
                                    Click="ButtonEdit_Click" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" Background="#FFFF6B6B" 
                                    Click="ButtonDelete_Click" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="ButtonAdd" Content="Добавить клиента" 
                    Width="150" Height="40" Margin="10" FontSize="14"
                    Background="#FFE9CB80" Click="ButtonAdd_Click"/>
            <Button x:Name="ButtonBack" Content="Назад" 
                    Width="100" Height="40" Margin="10" FontSize="14"
                    Background="#FF6D6D6D" Foreground="White" Click="ButtonBack_Click"/>
        </StackPanel>
    </Grid>
</Window>
