<Window x:Class="Laba4.Views.ClientEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование клиента" Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#FF2E2E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <Label Grid.Row="0" Content="{Binding Title}" 
               FontSize="24" HorizontalAlignment="Center" 
               Foreground="#FFE9CB80" VerticalAlignment="Center"/>
        
        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="ФИО:" Foreground="White" Margin="0,10,0,5"/>
            <TextBox x:Name="TextBoxFullName" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" Background="#FF6D6D6D" Foreground="White"/>
            
            <TextBlock Text="Email:" Foreground="White" Margin="0,10,0,5"/>
            <TextBox x:Name="TextBoxEmail" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" Background="#FF6D6D6D" Foreground="White"/>
            
            <TextBlock Text="Телефон:" Foreground="White" Margin="0,10,0,5"/>
            <TextBox x:Name="TextBoxPhone" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" Background="#FF6D6D6D" Foreground="White"/>
            
            <TextBlock Text="Адрес:" Foreground="White" Margin="0,10,0,5"/>
            <TextBox x:Name="TextBoxAddress" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" Background="#FF6D6D6D" Foreground="White"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="ButtonSave" Content="Сохранить" 
                    Width="120" Height="40" Margin="10" FontSize="14"
                    Background="#FFE9CB80" Click="ButtonSave_Click"/>
            <Button x:Name="ButtonCancel" Content="Отмена" 
                    Width="100" Height="40" Margin="10" FontSize="14"
                    Background="#FF6D6D6D" Foreground="White" Click="ButtonCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
