<Window x:Class="Laba4.Views.EmployeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление сотрудниками" Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF2E2E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <Label Grid.Row="0" Content="Сотрудники (Employees)" 
               FontSize="24" HorizontalAlignment="Center" 
               Foreground="#FFE9CB80" VerticalAlignment="Center"/>
        
        <DataGrid x:Name="DataGridEmployees" Grid.Row="1" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FF6D6D6D" Foreground="White"
                  SelectionMode="Single" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding EmployeeID}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Ставка/час" Binding="{Binding HourlyRate, StringFormat={}{0:F2}}" Width="100"/>
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Изменить" Background="#FFE9CB80" 
                                    Click="ButtonEdit_Click" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" Background="#FFFF6B6B" 
                                    Click="ButtonDelete_Click" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="ButtonAdd" Content="Добавить сотрудника" 
                    Width="170" Height="40" Margin="10" FontSize="14"
                    Background="#FFE9CB80" Click="ButtonAdd_Click"/>
            <Button x:Name="ButtonBack" Content="Назад" 
                    Width="100" Height="40" Margin="10" FontSize="14"
                    Background="#FF6D6D6D" Foreground="White" Click="ButtonBack_Click"/>
        </StackPanel>
    </Grid>
</Window>
